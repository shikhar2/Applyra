# ================================================================
# Applyra — Environment Configuration Template
# ================================================================

# ── AI Providers ───────────────────────────────────────────────
AI_PROVIDER=gemini  # Options: gemini, anthropic, openai
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Speed & Cost Optimization ──────────────────────────────────
# Use a cheaper/faster provider for simple tasks like Q&A
SIMPLER_AI_PROVIDER=groq
GROQ_API_KEY=
XAI_API_KEY=

# ── LinkedIn Credentials (for Easy Apply) ──────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Naukri Credentials (for Native Jobs) ──────────────────────
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# ── Application Safety Settings ───────────────────────────────
AUTO_APPLY_ENABLED=false
DRY_RUN=true
MAX_APPLICATIONS_PER_DAY=25
MIN_MATCH_SCORE=0.75

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/applyra.db

# ── Redis (Optional for Celery) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Scraper Settings ──────────────────────────────────────────
SCRAPER_DELAY_SECONDS=2.5
MAX_RETRIES=3

# ── Debug ─────────────────────────────────────────────────────
DEBUG=true
